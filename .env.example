# ─── Variables de entorno para producción (Netlify) ───────────
# Copia este archivo como .env.local para desarrollo local.
# En Netlify: Site settings → Environment variables → Add variable

# URL base de la API backend (sin slash final)
# Ejemplo producción: https://sems-api.railway.app/api
# Ejemplo local:      http://localhost:3000/api
VITE_API_URL=https://TU_BACKEND_URL/api
